{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Registered welfare member document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "passportNo": { "type": "string" },
        "omaniId": { "type": "string" },
        "registrationDate": { "type": "string" },
        "durationOfOmanStay": { "type": "string" },
        "profession": { "type": "string" },
        "isWelfareEligible": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "fullName", "phone", "passportNo", "omaniId", "status"]
    },
    "EmergencyReport": {
      "title": "EmergencyReport",
      "description": "Urgent medical / labor incident alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterPhone": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "category": { "type": "string", "enum": ["death", "accident", "lost_passport", "medical_need", "general"] },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "resolved"] }
      },
      "required": ["id", "reporterName", "reporterPhone", "severity", "category", "location", "description"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Financial welfare contribution log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "method": { "type": "string", "enum": ["bank", "mobile_pay"] },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] }
      },
      "required": ["id", "donorName", "amount", "method", "transactionId", "status"]
    },
    "Election": {
      "title": "Election",
      "description": "Cabinet election poll with candidates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "UrduTitle": { "type": "string" },
        "PashtoTitle": { "type": "string" },
        "date": { "type": "string" },
        "active": { "type": "boolean" },
        "candidates": { "type": "array" }
      },
      "required": ["id", "title", "active", "candidates"]
    },
    "NewsItem": {
      "title": "NewsItem",
      "description": "Bulletin news item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "UrduTitle": { "type": "string" },
        "PashtoTitle": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "UrduContent": { "type": "string" },
        "PashtoContent": { "type": "string" },
        "date": { "type": "string" },
        "important": { "type": "boolean" }
      },
      "required": ["id", "title", "category", "content", "date"]
    },
    "Advertisement": {
      "title": "Advertisement",
      "description": "Sponsor banner ad billboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sponsorName": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "tagline": { "type": "string" },
        "UrduTagline": { "type": "string" },
        "PashtoTagline": { "type": "string" },
        "clickUrl": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "sponsorName", "bannerUrl", "tagline"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Feedback suggestions inbox",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "name", "message", "date"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": { "$ref": "Member" },
      "description": "Welfare system registry of members"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "EmergencyReport" },
      "description": "Live status incidents dispatched"
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "Donation" },
      "description": "Audited donation ledger transactions"
    },
    "/elections/{electionId}": {
      "schema": { "$ref": "Election" },
      "description": "Cabinets executive polls"
    },
    "/news/{newsId}": {
      "schema": { "$ref": "NewsItem" },
      "description": "Direct reports and bulletin panels"
    },
    "/advertisements/{adId}": {
      "schema": { "$ref": "Advertisement" },
      "description": "Sponsored banner bills"
    },
    "/contactMessages/{msgId}": {
      "schema": { "$ref": "ContactMessage" },
      "description": "Contact panel entries"
    }
  }
}
